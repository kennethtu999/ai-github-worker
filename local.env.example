IMAGE_NAME=localhost/ai-github-worker:latest
CONTAINER_NAME=ai-github-worker-mvp
HOST_PORT=8080

GITHUB_TOKEN=replace_me
GITHUB_USER=replace_me
GITHUB_HOST=github.ibm.com
GITHUB_WEBHOOK_SECRET=replace_me
CODEX_API_KEY=replace_me

WORKER_DRY_RUN=true
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
SCHEDULER_INTERVAL_SECONDS=5
DEFAULT_BASE_BRANCH=main
CODEX_LOGS_DIR=/app/data/codex_logs
CODEX_AUTH_DIR=$HOME/.codex

